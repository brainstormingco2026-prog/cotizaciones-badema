# Base de datos (PostgreSQL)
# Ejemplo: postgresql://user:password@localhost:5432/crm_badema
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/crm_badema"

# JWT para sesiones
JWT_SECRET="generar-un-secreto-largo-y-aleatorio"

# API Contabilium (dejar vacío para usar datos simulados)
# Auth: grant_type=password — email de la cuenta + API Key
# Credenciales en: Mi cuenta → Configuración → API → Credenciales
CONTABILIUM_API_URL="https://rest.contabilium.com"
CONTABILIUM_EMAIL=""
CONTABILIUM_API_KEY=""
# Opcional: configuración avanzada
# CONTABILIUM_COTIZACIONES_PATH="/api/comprobantes/search"
# CONTABILIUM_VENDEDORES_PATH="/api/vendedores/getall"
# CONTABILIUM_FECHA_DESDE="01/01/2023"   # Por defecto: 2 años atrás (formato DD/MM/YYYY)

# Usar datos simulados en lugar de la API real (true = siempre mock; sin credenciales = mock automático)
USE_MOCK_CONTABILIUM="true"

# Origen de la app (para notificaciones / CORS)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Opcional: secreto para que un cron llame a /api/notifications/follow-up-alerts
CRON_SECRET=""
